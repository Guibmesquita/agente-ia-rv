+        function fmtRelativeTime(iso) {
+            if (!iso) return '—';
+            try {
+                var dt = new Date(iso);
+                if (isNaN(dt.getTime())) return '—';
+                var diff = Math.floor((Date.now() - dt.getTime()) / 1000);
+                if (diff < 0) {
+                    var future = Math.abs(diff);
+                    if (future < 60) return 'em ' + future + 's';
+                    if (future < 3600) return 'em ' + Math.floor(future / 60) + ' min';
+                    return 'em ' + Math.floor(future / 3600) + ' h';
+                }
+                if (diff < 60) return 'há ' + diff + 's';
+                if (diff < 3600) return 'há ' + Math.floor(diff / 60) + ' min';
+                if (diff < 86400) return 'há ' + Math.floor(diff / 3600) + ' h';
+                return 'há ' + Math.floor(diff / 86400) + ' dia(s)';
+            } catch (e) { return '—'; }
